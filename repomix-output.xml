                    )}

                    <li className={`page-item ${paging.page >= paging.totalPages ? "disabled" : ""}`}>
                      <button
                        type="button"
                        className="page-link"
                        onClick={() => setPage(paging.page + 1)}
                        disabled={paging.page >= paging.totalPages}
                      >
                        التالي
                      </button>
                    </li>
                  </ul>
                </nav>
              </div>
            </>
          )}
        </div>
      </div>

      <AdjustStockModal
        show={showAdjust}
        product={adjusting}
        busy={busy}
        error={err}
        onClose={() => setShowAdjust(false)}
        onSubmit={submitAdjust}
      />
    </div>
  );
}
