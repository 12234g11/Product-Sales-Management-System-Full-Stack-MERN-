security:
  - bearerAuth: []

paths:
  /api/auth/register:
    post:
      tags: [Auth]
      summary: Register workspace owner admin
      security: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AuthRegisterRequest'
      responses:
        '201':
          description: Registered successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/RegisterSuccessResponse'
        '400':
          description: Validation error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendError'
        '409':
          description: Email already exists
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendError'

  /api/auth/login:
    post:
      tags: [Auth]
      summary: Login
      security: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AuthLoginRequest'
      responses:
        '200':
          description: Logged in successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AuthSuccessResponse'
        '400':
          description: Missing email or password
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendError'
        '401':
          description: Invalid credentials
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendError'
        '403':
          description: User disabled
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendError'

  /api/auth/logout:
    post:
      tags: [Auth]
      summary: Logout current session family by incrementing tokenVersion
      responses:
        '200':
          description: Logged out successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/EmptySuccess'
        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendError'

  /api/products:
    get:
      tags: [Products]
      summary: List products in current workspace
      responses:
        '200':
          description: Products list
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductListResponse'
    post:
      tags: [Products]
      summary: Create product
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductCreateRequest'
      responses:
        '201':
          description: Product created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductResponse'
        '400':
          description: Validation or allowlist error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '409':
          description: Product id already exists
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'

  /api/products/low-stock:
    get:
      tags: [Products]
      summary: List low stock products using per-product minStock
      responses:
        '200':
          description: Low stock products
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductListResponse'

  /api/products/search:
    get:
      tags: [Products]
      summary: Search products
      parameters:
        - in: query
          name: id
          schema:
            type: string
          description: Case-insensitive partial match.
        - in: query
          name: name
          schema:
            type: string
        - in: query
          name: category
          schema:
            type: string
      responses:
        '200':
          description: Search result
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductListResponse'

  /api/products/auto-complete:
    get:
      tags: [Products]
      summary: Auto-complete products by id or name
      parameters:
        - in: query
          name: query
          schema:
            type: string
      responses:
        '200':
          description: Suggestions
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductListResponse'

  /api/products/auto-fill:
    get:
      tags: [Products]
      summary: Auto-fill product by business id or exact name
      parameters:
        - in: query
          name: id
          schema:
            type: string
        - in: query
          name: name
          schema:
            type: string
      responses:
        '200':
          description: Product found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductResponse'
        '400':
          description: id or name missing
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '404':
          description: Product not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '409':
          description: Multiple products have same name
          content:
            application/json:
              schema:
                type: object
                required: [status, data]
                properties:
                  status:
                    $ref: '#/components/schemas/StatusFail'
                  data:
                    type: object
                    properties:
                      message:
                        type: string
                      candidates:
                        type: array
                        items:
                          $ref: '#/components/schemas/ProductAutoFillConflictCandidate'

  /api/products/{id}:
    put:
      tags: [Products]
      summary: Update product by business id
      parameters:
        - $ref: '#/components/parameters/ProductBusinessIdParam'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductUpdateRequest'
      responses:
        '200':
          description: Product updated
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductResponse'
        '400':
          description: Validation or allowlist error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '404':
          description: Product not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '409':
          description: New product id already exists
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
    delete:
      tags: [Products]
      summary: Delete product by business id
      parameters:
        - $ref: '#/components/parameters/ProductBusinessIdParam'
      responses:
        '200':
          description: Product deleted
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/EmptySuccess'
        '404':
          description: Product not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'

  /api/products/{id}/adjust-stock:
    patch:
      tags: [Products]
      summary: Adjust product stock manually
      parameters:
        - $ref: '#/components/parameters/ProductBusinessIdParam'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ProductAdjustStockRequest'
      responses:
        '200':
          description: Stock adjusted and movement logged
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ProductAdjustStockResponse'
        '400':
          description: Validation error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '404':
          description: Product not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'
        '409':
          description: Stock changed, retry
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'

  /api/products/{id}/movements:
    get:
      tags: [Stock Movements]
      summary: List stock movements for a product
      parameters:
        - $ref: '#/components/parameters/ProductBusinessIdParam'
        - in: query
          name: type
          schema:
            type: string
            enum: [purchase, sale, sale_return, adjustment]
        - in: query
          name: refType
          schema:
            type: string
        - in: query
          name: refCode
          schema:
            type: string
        - in: query
          name: performedByName
          schema:
            type: string
        - in: query
          name: performedByUserId
          schema:
            $ref: '#/components/schemas/MongoId'
        - in: query
          name: reason
          schema:
            type: string
        - in: query
          name: direction
          schema:
            type: string
            enum: [in, out]
        - in: query
          name: from
          schema:
            type: string
            format: date
        - in: query
          name: to
          schema:
            type: string
            format: date
        - in: query
          name: q
          schema:
            type: string
        - in: query
          name: page
          schema:
            type: integer
            default: 1
        - in: query
          name: limit
          schema:
            type: integer
            default: 50
      responses:
        '200':
          description: Product movement history
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/StockMovementListResponse'
        '400':
          description: Invalid filter
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/JSendFail'

  /api/stock-movements:
    get:
      tags: [Stock Movements]
      summary: List stock movements in workspace
      parameters:
        - in: query
          name: type
          schema:
            type: string
            enum: [purchase, sale, sale_return, adjustment]
        - in: query
          name: productId
          schema:
            type: string
        - in: query
          name: refType
          schema:
            type: string
        - in: query
          name: refCode
          schema:
            type: string
