  if (!normalized) return "—";

  if (normalized === "inventory_count") return "جرد مخزني";
  if (normalized === "opening_balance") return "رصيد افتتاحي";
  if (normalized === "damaged") return "تالف";
  if (normalized === "correction") return "تصحيح";
